# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/devact

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# GitHub
GITHUB_TOKEN=your_github_personal_access_token

# Codeforces
CF_API_KEY=your_codeforces_api_key
